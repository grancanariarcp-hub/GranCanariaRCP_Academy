# ==========================================================
# Production environment (Render). Set these as env vars in
# the Render dashboard — do NOT commit real values.
# ==========================================================
NODE_ENV=production
# PORT is provided by Render automatically.

# Frontend origin(s) allowed by CORS (comma-separated).
CORS_ORIGIN=https://campus.grancanariarcp.es

# PostgreSQL (Neon). Neon requires SSL; the app enables it in production.
# Copy the "pooled" connection string from the Neon dashboard.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/grancanaria_rcp?sslmode=require

# Auth — generate strong random values:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_EXPIRES_IN=8h

# AES-256 key (exactly 64 hex chars):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# Super admin (Federico)
SUPERADMIN_EMAIL=grancanariarcp@gmail.com
SUPERADMIN_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
SUPERADMIN_NAME=Federico Lubbe

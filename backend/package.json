{
  "name": "grancanaria-rcp-backend",
  "version": "1.0.0",
  "description": "GranCanaria RCP Academy - Backend Express + PostgreSQL",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/postbuild.mjs",
    "start": "node dist/index.js",
    "db:setup": "tsx src/db/setup.ts",
    "db:setup:prod": "node dist/db/setup.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/setup.ts --reset",
    "db:backup": "tsx src/db/backup.ts",
    "db:limpiar-pruebas": "tsx src/db/limpiarPruebas.ts",
    "test": "tsx --test src/tests/*.test.ts",
    "humo": "tsx scripts/humo.ts"
  },
  "keywords": [
    "rcp",
    "cpr",
    "education",
    "express",
    "postgresql"
  ],
  "author": "Federico Lubbe",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@aws-sdk/s3-request-presigner": "^3.1089.0",
    "@types/multer": "^2.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "stripe": "^22.3.2",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.6",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
